page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.btn-primary {
  background: linear-gradient(135deg, #1296db 0%, #4da6ff 100%);
  color: #ffffff;
  border-radius: 40rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  background: #f5f5f5;
  color: #666666;
  border-radius: 40rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 32rpx;
  border: none;
}

.input-box {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.input-box:focus {
  border-color: #1296db;
  background: #ffffff;
}

.text-muted {
  color: #999999;
  font-size: 26rpx;
}

.text-primary {
  color: #1296db;
}

.text-success {
  color: #52c41a;
}

.text-danger {
  color: #ff4d4f;
}

.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1296db 0%, #4da6ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
}

.avatar-large {
  width: 120rpx;
  height: 120rpx;
  font-size: 48rpx;
}

.avatar-small {
  width: 60rpx;
  height: 60rpx;
  font-size: 24rpx;
}

.gap-sm {
  gap: 16rpx;
}

.gap-md {
  gap: 24rpx;
}

.gap-lg {
  gap: 32rpx;
}

.mt-sm {
  margin-top: 16rpx;
}

.mt-md {
  margin-top: 24rpx;
}

.mt-lg {
  margin-top: 32rpx;
}

.mb-sm {
  margin-bottom: 16rpx;
}

.mb-md {
  margin-bottom: 24rpx;
}

.mb-lg {
  margin-bottom: 32rpx;
}

.ml-sm {
  margin-left: 16rpx;
}

.mr-sm {
  margin-right: 16rpx;
}

.text-center {
  text-align: center;
}

.text-left {
  text-align: left;
}

.text-right {
  text-align: right;
}

.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}