.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 30rpx 30rpx;
  background: #ffffff;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #333333;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.placeholder {
  width: 60rpx;
}

.tabs {
  display: flex;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #1296db;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #1296db;
  border-radius: 2rpx;
}

.content {
  padding: 30rpx;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  color: #ffffff;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
}

.avatar-btn {
  margin-top: 20rpx;
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #1296db 0%, #4da6ff 100%);
  border-radius: 40rpx;
  color: #ffffff;
  font-size: 26rpx;
}

.input-item {
  margin-bottom: 30rpx;
}

.input-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.input-box {
  width: 100%;
  height: 88rpx;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
}

.textarea-box {
  width: 100%;
  height: 160rpx;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1296db 0%, #4da6ff 100%);
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
}

.btn-danger {
  width: 100%;
  height: 88rpx;
  background: #ff4d4f;
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
}

.warning-box {
  background: #fff7e6;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: flex-start;
}

.warning-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.warning-text {
  font-size: 26rpx;
  color: #d46b08;
  line-height: 1.5;
}

.error-msg {
  color: #ff4d4f;
  font-size: 26rpx;
  text-align: center;
  margin-top: 20rpx;
}