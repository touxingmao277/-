<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="title">添加好友</text>
    <view class="placeholder"></view>
  </view>
  
  <view class="search-section">
    <input 
      class="search-input" 
      type="text" 
      placeholder="搜索账号..."
      value="{{username}}"
      bindinput="handleUsernameInput"
      bindconfirm="handleSearch"
    />
    <button class="search-btn" bindtap="handleSearch">搜索</button>
  </view>
  
  <view class="error-msg" wx:if="{{errorMsg}}">
    <text>{{errorMsg}}</text>
  </view>
  
  <view wx:if="{{searchResult}}" class="result-section">
    <view class="result-card">
      <view class="avatar" style="background: {{searchResult.avatar ? 'url(' + searchResult.avatar + ')' : 'linear-gradient(135deg, #1296db 0%, #4da6ff 100%)'}}">
        <text wx:if="{{!searchResult.avatar}}">{{searchResult.nickname.charAt(0)}}</text>
      </view>
      <view class="result-info">
        <text class="nickname">{{searchResult.nickname}}</text>
        <text class="username">@{{searchResult.username}}</text>
      </view>
    </view>
    
    <view class="verify-section">
      <view class="verify-label">验证消息（选填）</view>
      <textarea 
        class="verify-textarea" 
        placeholder="输入验证消息（最多50字）"
        value="{{verifyMessage}}"
        bindinput="handleVerifyMessageInput"
        maxlength="50"
      />
      <text class="char-count">{{verifyMessage.length}}/50</text>
    </view>
    
    <button class="btn-primary mt-lg" bindtap="handleAddFriend">发送好友请求</button>
  </view>
</view>