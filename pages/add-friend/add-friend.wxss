.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 30rpx 30rpx;
  background: #ffffff;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #333333;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.placeholder {
  width: 60rpx;
}

.search-section {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

.search-input {
  flex: 1;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}

.search-btn {
  margin-left: 20rpx;
  padding: 16rpx 32rpx;
  background: #1296db;
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 28rpx;
}

.error-msg {
  padding: 20rpx 30rpx;
  color: #ff4d4f;
  font-size: 26rpx;
}

.result-section {
  padding: 30rpx;
}

.result-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.result-card .avatar {
  width: 100rpx;
  height: 100rpx;
}

.result-info {
  flex: 1;
  margin-left: 24rpx;
}

.result-info .nickname {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.result-info .username {
  font-size: 26rpx;
  color: #999999;
}

.verify-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.verify-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.verify-textarea {
  width: 100%;
  height: 120rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-top: 10rpx;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1296db 0%, #4da6ff 100%);
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
}