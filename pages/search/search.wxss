.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.search-header {
  display: flex;
  align-items: center;
  padding: 60rpx 30rpx 30rpx;
  background: #ffffff;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #333333;
}

.search-input {
  flex: 1;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  margin: 0 20rpx;
}

.search-btn {
  padding: 16rpx 32rpx;
  background: #1296db;
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 28rpx;
}

.search-result {
  padding: 20rpx;
}

.result-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 12rpx;
}

.result-item .avatar {
  width: 80rpx;
  height: 80rpx;
}

.result-info {
  flex: 1;
  margin-left: 20rpx;
}

.result-info .nickname {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  display: block;
}

.result-info .username {
  font-size: 24rpx;
  color: #999999;
}

.result-arrow {
  font-size: 36rpx;
  color: #cccccc;
}