<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <text class="title">新的朋友</text>
    <view class="placeholder"></view>
  </view>
  
  <scroll-view class="request-list" scroll-y>
    <view wx:if="{{!loading && requests.length === 0}}" class="empty-state">
      <view class="empty-icon">👋</view>
      <text class="empty-text">暂无好友请求</text>
    </view>
    
    <view 
      wx:for="{{requests}}" 
      wx:key="_id" 
      class="request-item"
    >
      <view class="avatar" style="background: {{item.fromUser.avatar ? 'url(' + item.fromUser.avatar + ')' : 'linear-gradient(135deg, #1296db 0%, #4da6ff 100%)'}}">
        <text wx:if="{{!item.fromUser.avatar}}">{{item.fromUser.nickname.charAt(0)}}</text>
      </view>
      <view class="request-info">
        <text class="nickname">{{item.fromUser.nickname}}</text>
        <text class="username">@{{item.fromUser.username}}</text>
        <text wx:if="{{item.verifyMessage}}" class="verify-message">{{item.verifyMessage}}</text>
      </view>
      <view class="action-buttons">
        <button class="reject-btn" bindtap="handleReject" data-request-id="{{item._id}}">拒绝</button>
        <button class="accept-btn" bindtap="handleAccept" data-request-id="{{item._id}}">同意</button>
      </view>
    </view>
  </scroll-view>
</view>