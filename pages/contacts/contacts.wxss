.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #ffffff;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

.header-right {
  display: flex;
  align-items: center;
}

.add-btn {
  width: 60rpx;
  height: 60rpx;
  background: #1296db;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.add-btn text {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 300;
}

.search-btn {
  font-size: 32rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

.search-input {
  flex: 1;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}

.search-bar button {
  margin-left: 20rpx;
  padding: 16rpx 32rpx;
  background: #1296db;
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 28rpx;
}

.search-result {
  background: #ffffff;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.result-item {
  display: flex;
  align-items: center;
}

.result-item .avatar {
  width: 80rpx;
  height: 80rpx;
}

.result-info {
  flex: 1;
  margin-left: 20rpx;
}

.result-info .nickname {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  display: block;
}

.result-info .username {
  font-size: 24rpx;
  color: #999999;
}

.add-btn-small {
  padding: 12rpx 24rpx;
  background: #1296db;
  color: #ffffff;
  border-radius: 24rpx;
  font-size: 26rpx;
}

.section {
  background: #ffffff;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.section-arrow {
  font-size: 36rpx;
  color: #cccccc;
}

.friend-list {
  height: calc(100vh - 300rpx);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
}

.friend-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

.friend-item:active {
  background: #f8f8f8;
}

.friend-info {
  flex: 1;
  margin-left: 24rpx;
}

.friend-info .nickname {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  display: block;
  margin-bottom: 6rpx;
}

.friend-info .signature {
  font-size: 24rpx;
  color: #999999;
}

.friend-arrow {
  font-size: 36rpx;
  color: #cccccc;
}