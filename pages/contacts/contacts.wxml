<view class="container">
  <view class="header">
    <text class="title">联系人</text>
    <view class="header-right">
      <view class="add-btn" bindtap="goToAddFriend">
        <text>+</text>
      </view>
      <view class="search-btn" bindtap="toggleSearch">
        <text>🔍</text>
      </view>
    </view>
  </view>
  
  <view wx:if="{{showSearch}}" class="search-bar">
    <input 
      class="search-input" 
      type="text" 
      placeholder="搜索账号..."
      value="{{searchText}}"
      bindinput="handleSearchInput"
      bindconfirm="handleSearch"
    />
    <button class="search-btn" bindtap="handleSearch">搜索</button>
  </view>
  
  <view wx:if="{{searchResult}}" class="search-result">
    <view class="result-item">
      <view class="avatar" style="background: {{searchResult.avatar ? 'url(' + searchResult.avatar + ')' : 'linear-gradient(135deg, #1296db 0%, #4da6ff 100%)'}}">
        <text wx:if="{{!searchResult.avatar}}">{{searchResult.nickname.charAt(0)}}</text>
      </view>
      <view class="result-info">
        <text class="nickname">{{searchResult.nickname}}</text>
        <text class="username">@{{searchResult.username}}</text>
      </view>
      <button class="add-btn-small" bindtap="handleAddFriend">
        <text>添加</text>
      </button>
    </view>
  </view>
  
  <view class="section">
    <view class="section-header" bindtap="goToFriendRequest">
      <text class="section-title">新的朋友</text>
      <text class="section-arrow">›</text>
    </view>
  </view>
  
  <scroll-view class="friend-list" scroll-y>
    <view wx:if="{{friends.length === 0}}" class="empty-state">
      <view class="empty-icon">👥</view>
      <text class="empty-text">暂无好友</text>
      <text class="empty-desc">点击右上角添加好友</text>
    </view>
    
    <view 
      wx:for="{{friends}}" 
      wx:key="_id" 
      class="friend-item"
      bindtap="goToChat"
      data-user-id="{{item._id}}"
      data-nickname="{{item.nickname}}"
      data-avatar="{{item.avatar}}"
    >
      <view class="avatar" style="background: {{item.avatar ? 'url(' + item.avatar + ')' : 'linear-gradient(135deg, #1296db 0%, #4da6ff 100%)'}}">
        <text wx:if="{{!item.avatar}}">{{item.nickname.charAt(0)}}</text>
      </view>
      <view class="friend-info">
        <text class="nickname">{{item.nickname}}</text>
        <text class="signature">{{item.signature || '暂无签名'}}</text>
      </view>
      <text class="friend-arrow">›</text>
    </view>
  </scroll-view>
</view>