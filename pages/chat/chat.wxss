.chat-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #e8e8e8;
}

.chat-header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e8e8e8;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #333333;
}

.header-info {
  flex: 1;
  display: flex;
  align-items: center;
  margin-left: 20rpx;
}

.header-info .avatar-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
}

.header-info .avatar-img {
  width: 100%;
  height: 100%;
}

.header-info .avatar-default {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-info .avatar-default text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
}

.header-info .nickname {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-left: 20rpx;
}

.header-right {
  width: 60rpx;
  display: flex;
  justify-content: center;
}

.more-icon {
  font-size: 40rpx;
  color: #666666;
}

.message-list {
  flex: 1;
  padding: 20rpx;
}

.message-item {
  display: flex;
  margin-bottom: 30rpx;
}

.message-item .avatar-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.message-item .avatar-default {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.message-item .avatar-default text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
}

.message-item.self {
  flex-direction: row-reverse;
}

.message-item.self .message-bubble {
  background: #1296db;
}

.message-item.self .text-message text {
  color: #ffffff;
}

.message-item.other .message-bubble {
  background: #ffffff;
}

.message-bubble {
  max-width: 70%;
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  margin: 0 16rpx;
}

.text-message text {
  font-size: 30rpx;
  color: #333333;
  word-break: break-all;
}

.image-message {
  max-width: 300rpx;
  max-height: 300rpx;
  border-radius: 12rpx;
}

.revoked-message {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
}

.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #ffffff;
  border-top: 1rpx solid #e8e8e8;
}

.input-left {
  display: flex;
  align-items: center;
}

.icon-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-btn text {
  font-size: 36rpx;
}

.input-box {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  margin: 0 20rpx;
}

.send-btn {
  width: 100rpx;
  height: 72rpx;
  background: #1296db;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #ffffff;
  border: none;
}

.send-btn[disabled] {
  background: #cccccc;
  color: #999999;
}