.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #ffffff;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

.publish-btn {
  background: #1296db;
  padding: 16rpx 28rpx;
  border-radius: 32rpx;
}

.publish-btn text {
  color: #ffffff;
  font-size: 26rpx;
}

.dynamic-list {
  height: calc(100vh - 80rpx);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
}

.dynamic-card {
  background: #ffffff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-header .avatar {
  width: 80rpx;
  height: 80rpx;
}

.user-info {
  margin-left: 20rpx;
}

.user-info .nickname {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  display: block;
}

.user-info .time {
  font-size: 22rpx;
  color: #999999;
}

.content {
  font-size: 30rpx;
  color: #333333;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.dynamic-image {
  width: calc(33.33% - 7rpx);
  height: 200rpx;
  border-radius: 12rpx;
}

.card-footer {
  display: flex;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-item {
  display: flex;
  align-items: center;
}

.action-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.action-text {
  font-size: 26rpx;
  color: #666666;
}

.comment-input-bar {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.comment-input {
  flex: 1;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}

.send-comment-btn {
  margin-left: 20rpx;
  padding: 16rpx 32rpx;
  background: #1296db;
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 28rpx;
}

.loading-more {
  text-align: center;
  padding: 20rpx;
  color: #999999;
  font-size: 26rpx;
}