.notify-badge {
  position: absolute;
  background: #ff4d4f;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.notify-badge.small {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
}

.notify-badge.medium {
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 10rpx;
}

.notify-badge.large {
  min-width: 48rpx;
  height: 48rpx;
  padding: 0 12rpx;
}

.badge-text {
  font-size: 20rpx;
  color: #ffffff;
  font-weight: 500;
}