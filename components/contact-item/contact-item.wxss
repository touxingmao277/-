.contact-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

.contact-item:active {
  background: #f8f8f8;
}

.contact-info {
  flex: 1;
  margin-left: 24rpx;
}

.contact-info .nickname {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  display: block;
  margin-bottom: 6rpx;
}

.contact-info .signature {
  font-size: 24rpx;
  color: #999999;
}

.arrow {
  font-size: 36rpx;
  color: #cccccc;
}